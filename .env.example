# Copy to .env and adjust. Never commit .env.
DATABASE_URL=postgresql+psycopg2://fallwatch:fallwatch_dev_password@localhost:5432/fallwatch

# Write-endpoint authentication: when set, POST/DELETE requests must send
# this value in the X-API-Key header (read endpoints stay public).
# Generate with: openssl rand -hex 24
#FALLWATCH_API_KEY=

# Alerts: falls at or above this confidence trigger notifications
ALERT_MIN_CONFIDENCE=0.7

# Optional email channel - activates when SMTP_HOST is set
# (for Gmail: smtp.gmail.com, port 587, app password)
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#ALERT_EMAIL_TO=
